{{ 'liquid-richtext' | append: '' }}
{%- comment -%}
  Section: Liquid Rich Text
  A rich text block themed around ink dissolving into water — a distorted,
  slowly-morphing SVG blob (SVG feTurbulence + feDisplacementMap, driven by
  GSAP) sits behind an editorial heading/body pair. The heading splits into
  words that rise through a clipped "surface" on scroll; the body content
  fades up paragraph by paragraph. No paid GSAP plugins are used — everything
  runs on the free GSAP core + ScrollTrigger, loaded from cdnjs on demand.
{%- endcomment -%}

<section
  class="liquid-rt liquid-rt--{{ section.settings.content_alignment }}"
  id="liquid-rt-{{ section.id }}"
  data-liquid-rt
  style="
    --rt-pt: {{ section.settings.padding_top }}px;
    --rt-pb: {{ section.settings.padding_bottom }}px;
    --rt-accent: {{ section.settings.accent_color }};
    --rt-accent-2: {{ section.settings.accent_color_2 }};
  "
>
  <svg class="liquid-rt__defs" width="0" height="0" aria-hidden="true" focusable="false">
    <filter id="liquid-turb-{{ section.id }}" x="-40%" y="-40%" width="180%" height="180%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.012 0.018"
        numOctaves="2"
        seed="7"
        result="rt-noise"
        data-rt-turbulence
      />
      <feDisplacementMap
        in="SourceGraphic"
        in2="rt-noise"
        scale="0"
        xChannelSelector="R"
        yChannelSelector="G"
        data-rt-displace
      />
    </filter>
    <linearGradient id="liquid-grad-{{ section.id }}" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="var(--rt-accent)" stop-opacity="0.85" />
      <stop offset="100%" stop-color="var(--rt-accent-2)" stop-opacity="0.55" />
    </linearGradient>
  </svg>

  <div class="liquid-rt__blob" aria-hidden="true" data-rt-blob>
    <svg viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
      <g filter="url(#liquid-turb-{{ section.id }})">
        <ellipse cx="230" cy="260" rx="230" ry="190" fill="url(#liquid-grad-{{ section.id }})" />
        <ellipse cx="390" cy="360" rx="150" ry="120" fill="var(--rt-accent)" opacity="0.28" />
      </g>
    </svg>
  </div>

  <div class="liquid-rt__inner">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="liquid-rt__eyebrow" data-rt-eyebrow>{{ section.settings.eyebrow_text }}</p>
    {%- endif -%}

    <h2 class="liquid-rt__heading" data-rt-heading aria-label="{{ section.settings.heading | strip_html }}">
      {%- assign rt_words = section.settings.heading | split: ' ' -%}
      {%- for word in rt_words -%}
        <span class="liquid-rt__word"><span class="liquid-rt__word-inner">{{ word }}</span></span>{% unless forloop.last %} {% endunless %}
      {%- endfor -%}
    </h2>

    {%- if section.settings.body != blank -%}
      <div class="liquid-rt__body rte" data-rt-body>
        {{ section.settings.body }}
      </div>
    {%- endif -%}

    {%- if section.settings.show_button and section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="liquid-rt__button"
        data-rt-button
      >
        <span>{{ section.settings.button_label }}</span>
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Newsreader:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@500&display=swap');

.liquid-rt {
  position: relative;
  overflow: hidden;
  padding-top: var(--rt-pt, 96px);
  padding-bottom: var(--rt-pb, 96px);
  padding-left: clamp(20px, 5vw, 64px);
  padding-right: clamp(20px, 5vw, 64px);
  background: radial-gradient(120% 140% at 20% 0%, #163534 0%, #0c1b1e 55%, #0a1516 100%);
  color: #ece4d0;
  isolation: isolate;
}

.liquid-rt__defs { position: absolute; width: 0; height: 0; }

.liquid-rt__blob {
  position: absolute;
  inset: -10% -10% -10% auto;
  width: min(60vw, 720px);
  height: 100%;
  right: -6%;
  top: 0;
  opacity: 0.9;
  filter: blur(0.5px);
  pointer-events: none;
  z-index: 0;
  mix-blend-mode: screen;
}
.liquid-rt__blob svg { width: 100%; height: 100%; }

.liquid-rt__inner {
  position: relative;
  z-index: 1;
  max-width: 760px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}
.liquid-rt--center { margin-inline: auto; align-items: center; text-align: center; }
.liquid-rt--center .liquid-rt__heading { justify-content: center; }
.liquid-rt--center .liquid-rt__body { text-align: left; }

.liquid-rt__eyebrow {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--rt-accent);
  margin: 0;
  opacity: 0;
}

.liquid-rt__heading {
  font-family: 'Fraunces', serif;
  font-weight: 600;
  font-size: clamp(32px, 5vw, 58px);
  line-height: 1.08;
  letter-spacing: -0.01em;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  row-gap: 0.05em;
  column-gap: 0.22em;
}
.liquid-rt__word { overflow: hidden; display: inline-block; }
.liquid-rt__word-inner { display: inline-block; will-change: transform; transform: translateY(115%); }

.liquid-rt__body {
  font-family: 'Newsreader', serif;
  font-size: 18px;
  line-height: 1.7;
  color: #cfd8d2;
  max-width: 58ch;
}
.liquid-rt__body > * { opacity: 0; transform: translateY(18px); }
.liquid-rt__body p + p { margin-top: 1em; }
.liquid-rt__body a { color: var(--rt-accent); text-decoration-thickness: 1px; text-underline-offset: 3px; }

.liquid-rt__button {
  align-self: flex-start;
  position: relative;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #0c1b1e;
  background: var(--rt-accent);
  padding: 14px 26px;
  border-radius: 999px;
  text-decoration: none;
  opacity: 0;
  transform: translateY(14px) scale(0.98);
}
.liquid-rt--center .liquid-rt__button { align-self: center; }

@media (max-width: 700px) {
  .liquid-rt__blob { width: 90vw; right: -20%; opacity: 0.6; }
}

@media (prefers-reduced-motion: reduce) {
  .liquid-rt__word-inner { transform: none; }
  .liquid-rt__eyebrow, .liquid-rt__body > *, .liquid-rt__button { opacity: 1; transform: none; }
}
{% endstylesheet %}

<script>
(function () {
  var CDN = {
    gsap: 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js',
    st: 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js'
  };

  function loadScript(src) {
    return new Promise(function (resolve, reject) {
      var existing = document.querySelector('script[data-rt-src="' + src + '"]');
      if (existing) {
        if (window.gsap && (src !== CDN.st || window.ScrollTrigger)) return resolve();
        existing.addEventListener('load', resolve);
        existing.addEventListener('error', reject);
        return;
      }
      var s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.setAttribute('data-rt-src', src);
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  function ensureGsap() {
    if (window.gsap && window.ScrollTrigger) return Promise.resolve();
    return loadScript(CDN.gsap).then(function () {
      return loadScript(CDN.st);
    }).then(function () {
      gsap.registerPlugin(ScrollTrigger);
    });
  }

  function initSection(root) {
    if (!root || root.dataset.rtInitialized) return;
    root.dataset.rtInitialized = 'true';

    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var eyebrow = root.querySelector('[data-rt-eyebrow]');
    var words = root.querySelectorAll('.liquid-rt__word-inner');
    var body = root.querySelector('[data-rt-body]');
    var bodyChildren = body ? Array.prototype.slice.call(body.children) : [];
    var button = root.querySelector('[data-rt-button]');
    var turbulence = root.querySelector('[data-rt-turbulence]');
    var displace = root.querySelector('[data-rt-displace]');

    if (prefersReduced) return;

    var tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: 'top 75%',
        once: true
      }
    });

    if (eyebrow) {
      tl.to(eyebrow, { opacity: 1, duration: 0.6, ease: 'power2.out' }, 0);
    }
    if (words.length) {
      tl.to(words, {
        y: '0%',
        duration: 1.1,
        ease: 'power4.out',
        stagger: 0.045
      }, 0.15);
    }
    if (bodyChildren.length) {
      tl.to(bodyChildren, {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power3.out',
        stagger: 0.12
      }, 0.5);
    }
    if (button) {
      tl.to(button, { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'back.out(1.7)' }, '>-0.3');
    }

    // Liquid blob: displacement "surfaces" in on scroll, then idles with a slow ripple.
    if (turbulence && displace) {
      gsap.timeline({
        scrollTrigger: { trigger: root, start: 'top 80%', once: true }
      }).to(displace, { attr: { scale: 42 }, duration: 1.6, ease: 'power2.out' })
        .add(function () {
          var proxy = { freq: 0.012 };
          gsap.to(proxy, {
            freq: 0.02,
            duration: 6,
            ease: 'sine.inOut',
            repeat: -1,
            yoyo: true,
            onUpdate: function () {
              turbulence.setAttribute('baseFrequency', proxy.freq + ' ' + (proxy.freq * 1.5).toFixed(4));
            }
          });
        });
    }
  }

  function initAll() {
    document.querySelectorAll('[data-liquid-rt]').forEach(initSection);
  }

  ensureGsap().then(initAll).catch(function (err) {
    console.warn('Liquid rich text: GSAP failed to load, showing static content.', err);
    document.querySelectorAll('[data-liquid-rt]').forEach(function (root) {
      root.querySelectorAll('.liquid-rt__word-inner, [data-rt-eyebrow], [data-rt-button]').forEach(function (el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      var body = root.querySelector('[data-rt-body]');
      if (body) {
        Array.prototype.forEach.call(body.children, function (el) {
          el.style.opacity = '1';
          el.style.transform = 'none';
        });
      }
    });
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {}, { once: true });
  }

  document.addEventListener('shopify:section:load', function (evt) {
    var root = evt.target.querySelector('[data-liquid-rt]');
    if (root) ensureGsap().then(function () { initSection(root); });
  });
})();
</script>

{% schema %}
{
  "name": "Liquid rich text",
  "tag": "section",
  "class": "shopify-section--liquid-richtext",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Field Notes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ink finds its own way down the page"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Write the paragraph that anchors this section. Each block of copy rises into place as it scrolls into view, the way ink settles once it stops spreading through water.</p>"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#5FE1C9"
    },
    {
      "type": "color",
      "id": "accent_color_2",
      "label": "Accent color 2",
      "default": "#8C7BFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "rich text"
    }
  ]
}
{% endschema %}
