{% liquid
  assign section_id = 'hero-' | append: section.id
%}

<section id="{{ section_id }}" class="hero-section">
  <div class="page-width">
    <h2 class="hero-title">{{ section.settings.heading }}</h2>
    <p class="hero-text">{{ section.settings.text }}</p>
    <a href="{{ section.settings.button_link }}" class="hero-button">
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

<style>
  #{{ section_id }} {
    padding: 80px 20px;
    text-align: center;
    background: #f8f8f8;
  }

  #{{ section_id }} .hero-title {
    font-size: 42px;
    opacity: 0;
  }

  #{{ section_id }} .hero-text {
    margin: 20px 0;
    opacity: 0;
  }

  #{{ section_id }} .hero-button {
    display: inline-block;
    padding: 12px 24px;
    background: #111;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    opacity: 0;
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const section = document.querySelector("#{{ section_id }}");

  if (!section || typeof gsap === "undefined") return;

  const tl = gsap.timeline({
    defaults: {
      duration: 0.8,
      ease: "power2.out"
    }
  });

  tl.from(section.querySelector(".hero-title"), {
      y: -40,
      opacity: 0
    })
    .addLabel("titleDone")
    .from(section.querySelector(".hero-text"), {
      y: 20,
      opacity: 0
    }, "titleDone-=0.3")
    .from(section.querySelector(".hero-button"), {
      scale: 0.8,
      opacity: 0
    }, "titleDone");
});
</script>

{% schema %}
{
  "name": "Hero GSAP",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Build beautiful Shopify stores with GSAP animations."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero GSAP"
    }
  ]
}
{% endschema %}