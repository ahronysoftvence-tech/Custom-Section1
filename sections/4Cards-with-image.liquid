{% comment %} {{ 'section-why-choose.css' | asset_url | stylesheet_tag }} {% endcomment %}

{%- style -%}
  #update-custom-4cards_with_image-{{ section.id }} {
    --update-custom-section-padding-top: {{ section.settings.padding_top }}px;
    --update-custom-section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --update-custom-section-background: {{ section.settings.background_color }};
    --update-custom-title-color: {{ section.settings.title_color }};
    --update-custom-subtitle-color: {{ section.settings.subtitle_color }};
    --update-custom-feature-title-color: {{ section.settings.feature_title_color }};
    --update-custom-feature-text-color: {{ section.settings.feature_text_color }};
    --update-custom-icon-background: {{ section.settings.icon_background }};
    --update-custom-divider-color: {{ section.settings.divider_color }};
    --update-custom-stats-background: {{ section.settings.stats_background }};
    --update-custom-stats-number-color: {{ section.settings.stats_number_color }};
    --update-custom-stats-text-color: {{ section.settings.stats_text_color }};
    --update-custom-icon-truck-color: {{ section.settings.icon_truck_color }};
    --update-custom-icon-truck-background: {{ section.settings.icon_truck_background }};
    padding-top: var(--update-custom-section-padding-top);
    padding-bottom: var(--update-custom-section-padding-bottom);
    background-color: var(--update-custom-section-background);
  }
{%- endstyle -%}

<div class="update-custom-wrapper" id="update-custom-4cards_with_image-{{ section.id }}">
  <div class="update-custom-main">
    <div class="update-custom-left">
      {%- if section.settings.subtitle != blank -%}
        <p class="update-custom-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1 class="update-custom-title">{{ section.settings.title }}</h1>
      {%- endif -%}
      
      <div class="update-custom-features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="update-custom-feature" {{ block.shopify_attributes }}>
              <div class="update-custom-icon-wrapper">
                {%- if block.settings.icon_image != blank -%}
                  <img 
                    src="{{ block.settings.icon_image | img_url: '100x100' }}" 
                    alt="{{ block.settings.icon_image.alt | escape }}" 
                    width="100" 
                    height="100" 
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="update-custom-placeholder-icon">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {%- endif -%}
              </div>
              
              {%- if block.settings.title != blank -%}
                <h2 class="update-custom-feature-title">{{ block.settings.title }}</h2>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <p class="update-custom-feature-text">{{ block.settings.description }}</p>
              {%- endif -%}
              
              <hr class="update-custom-divider">
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    
    <div class="update-custom-right">
      {%- if section.settings.main_image != blank -%}
        <img 
          src="{{ section.settings.main_image | img_url: '800x' }}" 
          alt="{{ section.settings.main_image.alt | escape }}" 
          loading="lazy" 
          width="800" 
          height="600"
          class="update-custom-main-image"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  /* Wrapper */
  .update-custom-wrapper {
    padding: 0 1rem;
  }
  
  .update-custom-main {
    align-items: center;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    justify-content: space-between;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .update-custom-main {
      grid-template-columns: 1.5fr 1fr;
      gap: 4rem;
    }
  }

  .update-custom-left {
    padding-right: 1rem;
  }

  .update-custom-subtitle {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    text-transform: capitalize;
    color: var(--update-custom-subtitle-color);
  }

  .update-custom-title {
    text-align: start;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    color: var(--update-custom-title-color);
    line-height: 1.25;
    margin-bottom: 3rem;
  }

  .update-custom-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 4rem;
    max-width: 100%;
  }

  @media (min-width: 640px) {
    .update-custom-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .update-custom-feature {
    position: relative;
    padding-right: 1rem;
  }

  .update-custom-icon-wrapper {
    width: 3rem;
    height: 3rem;
    background-color: var(--update-custom-icon-background);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  
  .update-custom-icon-wrapper img {
    width: 80%;
    height: 100%;
    object-fit: contain;
  }
  
  .update-custom-placeholder-icon {
    width: 60%;
    height: 60%;
    color: #E0C388;
  }

  .update-custom-feature-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--update-custom-feature-title-color);
    margin-bottom: 0.5rem;
    text-align: start;
  }

  .update-custom-feature-text {
    text-align: start;
    font-size: 1rem;
    line-height: 1.6;
    max-width: 22rem;
    color: var(--update-custom-feature-text-color);
    margin-bottom: 1.75rem;
  }

  .update-custom-divider {
    border: none;
    border-top: 1px solid var(--update-custom-divider-color);
    margin-top: 1.75rem;
    width: 80%;
  }

  .update-custom-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    width: 100%;
  }

  .update-custom-main-image {
    width: 100%;
    max-width: 100%;
    height: 530px;
    aspect-ratio: 3/4;
    object-fit: cover;
    display: block;
  }

  /* Mobile Adjustments */
  @media (max-width: 640px) {
    .update-custom-main {
      display: flex;
      flex-direction: column;
    }

    .update-custom-right {
      order: 1; /* Image first */
    }

    .update-custom-left {
      order: 2; /* Content after image */
      padding-right: 0;
    }

    .update-custom-title {
      text-align: center;
      margin-bottom: 2rem;
    }

    .update-custom-feature {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding-right: 0;
    }

    .update-custom-features {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .update-custom-feature-title,
    .update-custom-feature-text {
      text-align: center;
    }

    .update-custom-feature hr {
      width: 100%;
    }

    .update-custom-main-image {
      height: 350px;
      max-height: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "4cards_with_image",
  "tag": "section",
  "class": "update-custom-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Promise"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why choose Abijah Wear?"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#2f2f2f"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our pieces are crafted with the finest materials, ensuring durability and comfort in every wear."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "4cards_with_image",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Premium Quality",
            "description": "Our pieces are crafted with the finest materials, ensuring durability and comfort in every wear."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Bold Designs",
            "description": "Featuring our signature gold Knights crest, each item embodies the power and confidence of luxury streetwear."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Streetwear with Purpose",
            "description": "Designed for those who move with intent, our pieces stand as a reflection of your drive and ambition."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Timeless Style",
            "description": "Our black and gold aesthetic transcends trends, offering you a stylish look that never goes out of fashion."
          }
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
